# ================================================================================
# Newsletter Generator - Environment Configuration Template
# ================================================================================
# 1. Copy this file to .env
# 2. Fill in your actual API keys and configuration values
# 3. Never commit .env file to version control
# ================================================================================

# ========================================
# Core LLM API Keys (At least one required)
# ========================================
# Choose at least one LLM provider for the system to work
GEMINI_API_KEY=your-google-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ========================================
# News Collection API (Required)
# ========================================
# Serper API for Google search results
SERPER_API_KEY=your-serper-api-key-here

# ========================================
# Email Delivery (Required for email sending)
# ========================================
# Postmark email service configuration
POSTMARK_SERVER_TOKEN=your-postmark-server-token-here
EMAIL_SENDER=newsletter@yourdomain.com

# ========================================
# Optional: Additional News Sources
# ========================================
# Naver API for Korean news (optional)
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# RSS Feeds (comma-separated URLs)
RSS_FEEDS=https://feeds.example.com/tech,https://feeds.example.com/ai

# ========================================
# Google Services (Optional)
# ========================================
# For Google Drive storage
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/google-credentials.json

# ========================================
# Application Settings
# ========================================
# Environment: development, staging, production
APP_ENV=development

# Mock mode for testing without API calls
MOCK_MODE=false
TESTING=false

# Application language preference
DEFAULT_LANGUAGE=ko  # ko for Korean, en for English

# ========================================
# Web Interface Settings
# ========================================
# Flask application settings
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=your-secret-key-for-sessions-change-in-production

# Server configuration
HOST=0.0.0.0
PORT=5000

# ========================================
# Database & Storage
# ========================================
# SQLite database for web interface
DATABASE_URL=sqlite:///./data/newsletter.db

# Redis for background jobs (optional)
REDIS_URL=redis://localhost:6379/0

# ========================================
# Security & Rate Limiting
# ========================================
# Rate limiting configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=100

# CORS settings
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# ========================================
# Monitoring & Logging (Optional)
# ========================================
# Sentry error tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_TRACES_SAMPLE_RATE=0.1

# Langsmith tracing (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=newsletter-generator

# Logging configuration
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_MAX_BYTES=10485760  # 10MB
LOG_FILE_BACKUP_COUNT=5

# ========================================
# Advanced Settings
# ========================================
# LLM temperature settings (0.0 to 1.0)
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# Newsletter generation settings
MAX_ARTICLES_PER_KEYWORD=5
MAX_NEWSLETTER_LENGTH=10000
NEWSLETTER_TEMPLATE_STYLE=modern  # modern, classic, compact

# Content filtering
FILTER_DUPLICATE_ARTICLES=true
MIN_ARTICLE_QUALITY_SCORE=0.5

# Timezone for scheduling
TIMEZONE=Asia/Seoul

# ========================================
# Development Tools
# ========================================
# Enable debug mode for detailed logging
DEBUG=true

# PyInstaller build settings
PYINSTALLER_LOG_LEVEL=ERROR

# Windows UTF-8 encoding
PYTHONIOENCODING=utf-8
PYTHONUTF8=1

# ========================================
# Notes
# ========================================
# 1. API Keys can be obtained from:
#    - Gemini: https://makersuite.google.com/app/apikey
#    - OpenAI: https://platform.openai.com/api-keys
#    - Anthropic: https://console.anthropic.com/
#    - Serper: https://serper.dev/
#    - Postmark: https://postmarkapp.com/
#
# 2. For production deployment:
#    - Set APP_ENV=production
#    - Set FLASK_ENV=production
#    - Set DEBUG=false
#    - Use strong SECRET_KEY
#    - Configure proper database (PostgreSQL recommended)
#
# 3. For Windows users:
#    - Ensure PYTHONIOENCODING=utf-8 is set
#    - Use forward slashes in file paths
#
# 4. Security reminders:
#    - Never commit .env file to git
#    - Rotate API keys regularly
#    - Use environment-specific configurations
# ================================================================================

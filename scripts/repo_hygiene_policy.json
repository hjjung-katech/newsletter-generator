{
  "schema_version": 1,
  "policy_name": "repo-hygiene-week1-baseline",
  "root_policy": {
    "allowed_file_names": [
      ".dockerignore",
      ".env.example",
      ".gitignore",
      ".gitmessage.txt",
      ".pre-commit-config.yaml",
      ".secrets.baseline",
      "AGENTS.md",
      "CHANGELOG.md",
      "CODEOWNERS",
      "Dockerfile",
      "LICENSE",
      "Makefile",
      "README.md",
      "nixpacks.toml",
      "pyproject.toml",
      "railway.yml",
      "requirements-dev.txt",
      "requirements.txt",
      "run_ci_checks.py"
    ],
    "allowed_file_globs": [],
    "allowed_directory_names": [
      ".agents",
      ".github",
      ".release",
      "apps",
      "config",
      "docs",
      "newsletter",
      "newsletter_core",
      "scripts",
      "tests",
      "web"
    ],
    "move_to_scripts_file_globs": [
      "build_*.py",
      "check_quality.py",
      "cleanup_*.py",
      "fix_*.py",
      "newsletter-test.bat",
      "newsletter-test.sh",
      "run_tests.py",
      "setup_env.py"
    ],
    "shim_file_names": [],
    "ignore_file_globs": [
      ".DS_Store",
      "*.zip"
    ],
    "ignore_directory_names": [
      ".local",
      ".mypy_cache",
      ".pytest_cache",
      ".venv",
      ".vscode",
      ".githooks",
      "__pycache__",
      "output"
    ]
  },
  "dot_directory_policy": {
    ".agents": {
      "mode": "conditional",
      "purpose": "장기 에이전트 실행에 필요한 스킬 정의만 추적",
      "allowed_tracked_file_globs": [
        ".agents/skills/*/SKILL.md",
        ".agents/skills/*/agents/openai.yaml"
      ]
    },
    ".release": {
      "mode": "required",
      "purpose": "release manifest 및 검증 정책",
      "allowed_tracked_file_globs": [
        ".release/**"
      ]
    },
    ".github": {
      "mode": "required",
      "purpose": "CI/CD workflows",
      "allowed_tracked_file_globs": [
        ".github/**"
      ]
    }
  }
}
